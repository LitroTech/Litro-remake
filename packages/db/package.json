{
  "name": "@litro/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env -e ../../apps/api/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env -e ../../apps/api/.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e .env -e ../../apps/api/.env -- drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "dotenv": "^16.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
